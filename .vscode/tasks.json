{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build SFML",
            "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${fileDirname}\\main.cpp",
                "${fileDirname}\\imgui\\imgui.cpp",
                "${fileDirname}\\imgui\\imgui_draw.cpp",
                "${fileDirname}\\imgui\\imgui_tables.cpp",
                "${fileDirname}\\imgui\\imgui_widgets.cpp",
                "${fileDirname}\\imgui\\imgui-SFML.cpp",
                "-I${fileDirname}\\imgui",
                "-o",
                "${fileDirname}\\game.exe",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "-lopengl32",
                "-static-libgcc",
                "-static-libstdc++"
            ],
            "options": {
                "cwd": "${fileDirname}",
                "env": {
                    "PATH": "C:\\msys64\\mingw64\\bin;${env:PATH}"
                }
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}